---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

// 1. Generate a new path for every collection entry
export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.id }, props: { entry },
  }));
}

// 2. For your template, you can get the entry directly from the prop
const { entry } = Astro.props;
const { Content } = await render(entry);

const formatDate = (date: Date) => {
  return date.toLocaleDateString('it-IT', { year: 'numeric', month: 'long', day: 'numeric' });
};
---

<Layout title={entry.data.title} description={entry.data.excerpt} image={entry.data.coverImage}>
  <Header />

  <main class="flex-grow pt-28 pb-20">
    <article class="max-w-3xl mx-auto px-4 md:px-6">
      
      <!-- Intestazione post -->
      <header class="mb-10 lg:mb-14 text-center">
        <time datetime={entry.data.date.toISOString()} class="text-sm font-mono text-secondary font-medium bg-secondary/10 px-3 py-1.5 rounded-full mb-6 inline-flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
          {formatDate(entry.data.date)}
        </time>
        
        <h1 class="text-3xl md:text-5xl font-display font-medium text-text leading-tight mb-6">
          {entry.data.title}
        </h1>
        
        <div class="flex flex-wrap items-center justify-center gap-2 mb-8">
          {entry.data.tags.map((tag: string) => (
            <span class="text-xs font-medium text-primary bg-surface px-2.5 py-1 rounded-md border border-primary/10">
              {tag}
            </span>
          ))}
        </div>
        
        {entry.data.coverImage && (
          <div class="w-full aspect-[21/9] rounded-2xl overflow-hidden shadow-lg border border-primary/5 mt-8 relative">
            <img 
              src={entry.data.coverImage} 
              alt={entry.data.title} 
              class="w-full h-full object-cover" 
            />
          </div>
        )}
      </header>

      <!-- Contenuto -->
      <div class="prose prose-lg md:prose-xl prose-p:text-muted prose-headings:font-display prose-headings:text-text prose-a:text-primary hover:prose-a:text-secondary max-w-none mx-auto
                  prose-h2:text-2xl md:prose-h2:text-3xl prose-h2:mt-12 prose-h2:mb-6
                  prose-h3:text-xl md:prose-h3:text-2xl prose-h3:mt-8 prose-h3:mb-4
                  prose-li:text-muted">
        <Content />
      </div>

      <!-- Condivisione & Back -->
      <footer class="mt-16 pt-8 border-t border-primary/10">
        <div class="flex flex-col sm:flex-row justify-between items-center gap-6">
           <a href="/blog" class="inline-flex items-center gap-2 text-primary hover:text-secondary font-medium transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
            Torna agli articoli
           </a>
           
           <!-- Dummy share buttons for aesthetics -->
           <div class="flex items-center gap-3">
             <span class="text-sm font-medium text-muted">Condividi:</span>
             <button class="w-10 h-10 rounded-full bg-surface text-primary flex items-center justify-center hover:bg-primary hover:text-white transition-colors" aria-label="Condividi su Facebook">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
             </button>
             <button class="w-10 h-10 rounded-full bg-surface text-primary flex items-center justify-center hover:bg-primary hover:text-white transition-colors" aria-label="Condividi tramite Email">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
             </button>
           </div>
        </div>
      </footer>
    </article>
  </main>
  
  <Footer />
</Layout>
