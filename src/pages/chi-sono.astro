---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const timeline = [
  {
    year: "Feb 2026",
    title: "Abilitazione all'esercizio della professione",
    description: "Iscrizione all'Albo degli Psicologi della Toscana n° 11853."
  },
  {
    year: "Gen-Set 2025",
    title: "Tirocinio professionalizzante",
    description: "Presso l'Associazione Italiana Malattia di Alzheimer – Firenze. Esperienza maturata nel sostegno ai caregiver e conduzione di gruppi psicoeducativi."
  },
  {
    year: "2022-2024",
    title: "Laurea Magistrale in Psicologia Clinica, del Lavoro e dello Sviluppo",
    description: "Università degli Studi Guglielmo Marconi."
  },
  {
    year: "2019-2022",
    title: "Laurea Triennale in Scienze e Tecniche Psicologiche",
    description: "Università degli Studi Guglielmo Marconi."
  }
];

const tags = [
  "Diagnosi differenziale Disturbi d'Ansia",
  "Teacher/Parent Training – Disturbo Oppositivo Provocatorio",
  "Gestione attacco di panico (professionisti)",
  "Bisogni Educativi Speciali",
  "ADHD"
];
---

<Layout title="Chi sono" description="Conosci Elisa Ardinghi, psicologa clinica iscritta all'Albo della Toscana. Scopri il suo percorso e le sue specializzazioni.">
  <Header />
  
  <main class="flex-grow pt-28 pb-20">
    
    <!-- Intro Header -->
    <section class="max-w-4xl mx-auto px-4 md:px-6 mb-16 md:mb-24 text-center">
      <h1 class="text-4xl md:text-5xl font-display font-medium text-text mb-6">Chi sono</h1>
      <div class="w-20 h-1 bg-primary mx-auto rounded-full"></div>
    </section>

    <!-- Bio Section -->
    <section class="max-w-5xl mx-auto px-4 md:px-6 mb-24">
      <div class="flex flex-col md:flex-row gap-12 items-center">
        <!-- Foto -->
        <div class="w-full md:w-2/5 aspect-[3/4] rounded-2xl overflow-hidden shadow-xl border-4 border-surface relative">
          <img src="/images/elisa-hero.jpg" alt="Ritratto di Elisa Ardinghi" class="w-full h-full object-cover bg-secondary/20" onerror="this.onerror=null; this.src='data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSIxMDAlIiBoZWlnaHQ9IjEwMCUiPjxyZWN0IHdpZHRoPSIxMDAlIiBoZWlnaHQ9IjEwMCUiIGZpbGw9IiNDMDg0QjAiIG9wYWNpdHk9IjAuMSIvPjwvc3ZnPg==';" />
          <div class="absolute inset-0 bg-primary/5 mix-blend-multiply"></div>
        </div>
        
        <!-- Testo Lungo -->
        <div class="w-full md:w-3/5 prose prose-lg prose-p:text-muted prose-p:leading-relaxed max-w-none">
          <p class="text-xl md:text-2xl font-display text-text font-medium mb-6 leading-tight">
            "Sono orientata alla costruzione di una solida alleanza terapeutica e all'integrazione mente-corpo nel percorso clinico."
          </p>
          <p>
            Sono una psicologa laureata in Psicologia Clinica, del Lavoro e dello Sviluppo, con un particolare interesse per la presa in carico della cronicità psichica e della malattia fisica cronica. 
          </p>
          <p>
            Credo profondamente nello spazio condiviso che si crea tra terapeuta e paziente: un luogo non giudicante dove l'ascolto e l'empatia sono i principali strumenti di cura. La mia pratica integra un approccio contemporaneo e umano, dedicato a supportare la persona in ogni fase del suo ciclo di vita.
          </p>
        </div>
      </div>
    </section>

    <!-- Formazione Timeline -->
    <section class="bg-surface py-24 mb-24">
      <div class="max-w-4xl mx-auto px-4 md:px-6">
        <div class="text-center mb-16">
          <h2 class="text-3xl font-display font-medium text-text">Il mio percorso</h2>
        </div>
        
        <div class="relative border-l-2 border-primary/20 ml-3 md:ml-6 space-y-12">
          {timeline.map(item => (
            <div class="relative pl-8 md:pl-10">
              <!-- Endpoint dot -->
              <div class="absolute w-4 h-4 rounded-full bg-primary -left-[9px] top-1.5 ring-4 ring-surface"></div>
              
              <span class="text-sm font-mono text-secondary font-medium tracking-wide bg-secondary/10 px-3 py-1 rounded-full mb-3 inline-block">
                {item.year}
              </span>
              <h3 class="text-xl font-display font-medium text-text mb-2">{item.title}</h3>
              <p class="text-muted leading-relaxed">{item.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Formazione Continua -->
    <section class="max-w-4xl mx-auto px-4 md:px-6 mb-24 text-center">
      <h2 class="text-3xl font-display font-medium text-text mb-10">Formazione continua</h2>
      <div class="flex flex-wrap justify-center gap-3 md:gap-4">
        {tags.map(tag => (
          <span class="px-5 py-3 bg-bg border border-primary/20 text-text rounded-2xl shadow-sm text-sm font-medium hover:border-primary/50 transition-colors">
            {tag}
          </span>
        ))}
      </div>
    </section>

    <!-- CTA Finale -->
    <section class="max-w-3xl mx-auto px-4 md:px-6 text-center">
      <div class="bg-primary/5 border border-primary/10 rounded-3xl p-10 md:p-14 shadow-sm">
        <h2 class="text-2xl md:text-3xl font-display font-medium text-text mb-4">Iniziamo un percorso insieme</h2>
        <p class="text-muted mb-8 text-lg">
          Se senti il bisogno di supporto o di uno spazio di ascolto dedicato, possiamo fissare un primo colloquio conoscitivo.
        </p>
        <a href="/#prenota" class="inline-block bg-primary text-white hover:bg-secondary px-8 py-4 rounded-xl text-lg font-medium transition-all shadow-md hover:shadow-lg transform hover:-translate-y-0.5">
          Prenota un colloquio
        </a>
      </div>
    </section>

  </main>

  <Footer />
</Layout>
