---
// Pagina "Chi sono": contenuto gestito su Storyblok (storia "chi-sono")
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { useStoryblokApi } from '@storyblok/astro';
import StoryblokComponent from '@storyblok/astro/StoryblokComponent.astro';

const storyblokApi = useStoryblokApi();
const { data } = await storyblokApi.get('cdn/stories/chi-sono', {
  version: import.meta.env.DEV ? 'draft' : 'published',
});
const content = data.story.content;
---

<Layout title="Chi sono" description="Conosci Elisa Ardinghi, psicologa clinica iscritta all'Albo della Toscana. Scopri il suo percorso e le sue specializzazioni.">
  <Header />

  <main class="flex-grow pt-28 pb-20">

    <!-- Header della pagina "Chi sono" -->
    <section class="max-w-4xl mx-auto px-4 md:px-6 mb-16 md:mb-24 text-center">
      <h1 class="text-4xl md:text-5xl font-display font-medium text-text mb-6">Chi sono</h1>
      <div class="w-20 h-1 bg-primary mx-auto rounded-full"></div>
    </section>

    {content.body?.map((blok) => (
      <StoryblokComponent blok={blok} />
    ))}

  </main>

  <Footer />
</Layout>
