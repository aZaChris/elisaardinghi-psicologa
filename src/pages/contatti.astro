---
// Pagina "Contatti": intro e recapiti da Storyblok (storia "contatti");
// form Web3Forms e mappa restano invariati (non sono contenuto editoriale)
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { useStoryblokApi } from '@storyblok/astro';
import StoryblokComponent from '@storyblok/astro/StoryblokComponent.astro';

const web3formsKey = import.meta.env.PUBLIC_WEB3FORMS_KEY || "YOUR_ACCESS_KEY_HERE";

const storyblokApi = useStoryblokApi();
const { data } = await storyblokApi.get('cdn/stories/contatti', {
  version: import.meta.env.DEV ? 'draft' : 'published',
});
const content = data.story.content;
const introBlok = content.body?.find((b) => b.component === 'contact_intro');
const infoBlok = content.body?.find((b) => b.component === 'contact_info');
---

<Layout title="Contatti" description="Contatta la Dott.ssa Elisa Ardinghi per prenotare un colloquio o ricevere maggiori informazioni.">
  <Header />

  <main class="flex-grow pt-28 pb-24">

    <section class="max-w-6xl mx-auto px-4 md:px-6">
      {introBlok && <StoryblokComponent blok={introBlok} />}

      <div class="flex flex-col lg:flex-row gap-12 lg:gap-20">
        <!-- Colonna Sinistra: Form di contatto Web3Forms -->
        <div class="w-full lg:w-3/5 bg-surface p-8 md:p-12 rounded-3xl border border-primary/10 shadow-sm">
          <h2 class="text-2xl font-display font-medium text-text mb-8">Scrivimi</h2>

          <form id="contact-form" class="space-y-6">
            <!-- Campi nascosti richiesti da Web3Forms per il corretto funzionamento -->
            <input type="hidden" name="access_key" value={web3formsKey}>
            <input type="hidden" name="subject" value="Nuovo messaggio dal sito web - Elisa Ardinghi">
            <!-- Protezione antispam (Honeypot) -->
            <input type="checkbox" name="botcheck" id="" style="display: none;">

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="space-y-2">
                <label for="name" class="block text-sm font-medium text-text">Nome e Cognome *</label>
                <input type="text" id="name" name="name" required class="w-full px-4 py-3 rounded-xl border border-primary/20 bg-bg text-text focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-all">
              </div>
              <div class="space-y-2">
                <label for="email" class="block text-sm font-medium text-text">Email *</label>
                <input type="email" id="email" name="email" required class="w-full px-4 py-3 rounded-xl border border-primary/20 bg-bg text-text focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-all">
              </div>
            </div>

            <div class="space-y-2">
              <label for="phone" class="block text-sm font-medium text-text">Telefono (opzionale)</label>
              <input type="tel" id="phone" name="phone" class="w-full px-4 py-3 rounded-xl border border-primary/20 bg-bg text-text focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-all">
            </div>

            <div class="space-y-2">
              <label for="message" class="block text-sm font-medium text-text">Messaggio *</label>
              <textarea id="message" name="message" rows="5" required class="w-full px-4 py-3 rounded-xl border border-primary/20 bg-bg text-text focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-all resize-none"></textarea>
            </div>

            <!-- Accettazione Privacy GDPR -->
            <div class="flex items-start gap-3">
              <input type="checkbox" id="privacy" name="privacy" required class="mt-1 w-4 h-4 rounded text-primary focus:ring-primary/50">
              <label for="privacy" class="text-sm text-muted">
                Acconsento al trattamento dei miei dati personali al solo fine di essere ricontattato in risposta alla mia richiesta, in conformità con la normativa vigente sulla Privacy (GDPR). *
              </label>
            </div>

            <button type="submit" id="submit-btn" class="w-full bg-primary text-white hover:bg-secondary px-8 py-4 rounded-xl text-lg font-medium transition-all shadow-md mt-4">
              Invia messaggio
            </button>
            <!-- Messaggio di feedback sull'invio (successo/errore) -->
            <p id="result-msg" class="text-center mt-4 hidden text-sm font-medium"></p>
          </form>
        </div>

        <!-- Colonna Destra: Informazioni di contatto e Mappa -->
        <div class="w-full lg:w-2/5 flex flex-col justify-between">
          {infoBlok && <StoryblokComponent blok={infoBlok} />}

          <!-- Mappa iframe (Posizionata su Cintolese PT) -->
          <div class="w-full bg-surface rounded-3xl overflow-hidden border border-primary/10 h-64 shadow-sm relative grayscale hover:grayscale-0 transition-all duration-700">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1m3!1d11516.480282470716!2d10.83546731005886!3d43.853245452296726!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x132a76f6b1e6ebaf%3A0xe5a3bb406c1ecf42!2s51015%20Cintolese%20PT!5e0!3m2!1sit!2sit!4v1700000000000!5m2!1sit!2sit"
              width="100%"
              height="100%"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade">
            </iframe>
            <div class="absolute inset-0 pointer-events-none ring-1 ring-inset ring-black/5 rounded-3xl"></div>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<script>
  // Logica lato client per l'invio asincrono del form a Web3Forms
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const resultMsg = document.getElementById('result-msg');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  form?.addEventListener('submit', function(e) {
    e.preventDefault();
    if (!form || !resultMsg || !submitBtn) return;

    // Estrazione dei dati dal form e conversione in JSON
    const formData = new FormData(form);
    const object = Object.fromEntries(formData);
    const json = JSON.stringify(object);

    // Feedback visivo dell'invio in corso
    resultMsg.innerHTML = "Invio in corso...";
    resultMsg.classList.remove('hidden', 'text-green-600', 'text-red-600');
    resultMsg.classList.add('text-muted');
    submitBtn.disabled = true;
    submitBtn.classList.add('opacity-70', 'cursor-not-allowed');

    // Chiamata all'API di Web3Forms
    fetch('https://api.web3forms.com/submit', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Accept': 'application/json'
      },
      body: json
    })
    .then(async (response) => {
      let json = await response.json();
      if (response.status == 200) {
        // Successo: svuota il form e comunica all'utente
        resultMsg.innerHTML = "Messaggio inviato con successo! Ti risponderò al più presto.";
        resultMsg.classList.remove('text-muted', 'text-red-600');
        resultMsg.classList.add('text-green-600');
        form.reset();
      } else {
        // Errore restituito dall'API
        console.log(response);
        resultMsg.innerHTML = json.message || "Si è verificato un errore. Riprova più tardi.";
        resultMsg.classList.remove('text-muted', 'text-green-600');
        resultMsg.classList.add('text-red-600');
      }
    })
    .catch(error => {
      // Errore di connessione o di rete
      console.log(error);
      resultMsg.innerHTML = "Errore di connessione. Controlla la tua rete e riprova.";
      resultMsg.classList.remove('text-muted', 'text-green-600');
      resultMsg.classList.add('text-red-600');
    })
    .finally(() => {
      // Ripristina lo stato del pulsante
      submitBtn.disabled = false;
      submitBtn.classList.remove('opacity-70', 'cursor-not-allowed');
      // Nasconde il messaggio di feedback dopo 5 secondi
      setTimeout(() => {
        resultMsg.classList.add('hidden');
      }, 5000);
    });
  });
</script>
