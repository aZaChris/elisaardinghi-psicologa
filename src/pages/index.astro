---
// Home Page: contenuto gestito su Storyblok (storia "home"), composta da
// blocchi (bloks) mappati in astro.config.mjs. Editing visuale da Elisa,
// nessun testo hardcoded qui.
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { useStoryblokApi } from '@storyblok/astro';
import StoryblokComponent from '@storyblok/astro/StoryblokComponent.astro';

const storyblokApi = useStoryblokApi();
const { data } = await storyblokApi.get('cdn/stories/home', {
  version: import.meta.env.DEV ? 'draft' : 'published',
});
const content = data.story.content;
---

<Layout>
  <!-- Header di navigazione uguale per tutto il sito -->
  <Header />

  <main class="flex-grow">
    {content.body?.map((blok) => (
      <StoryblokComponent blok={blok} />
    ))}
  </main>

  <!-- Footer comune -->
  <Footer />
</Layout>
