---
// Blok "services_grid": griglia di card "Aree di intervento", con lista di
// service_card riordinabile/estendibile da Storyblok.
import { storyblokEditable } from '@storyblok/astro';
import StoryblokComponent from '@storyblok/astro/StoryblokComponent.astro';

const { blok } = Astro.props;
---

<section {...storyblokEditable(blok)} id="aree-intervento" class="py-24 bg-surface relative">
  <div class="max-w-6xl mx-auto px-4 md:px-6">
    <div class="text-center mb-16">
      <span class="text-secondary font-medium tracking-wider uppercase text-sm mb-3 block">{blok.eyebrow}</span>
      <h2 class="text-3xl md:text-4xl font-display font-medium text-text">{blok.title}</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {blok.cards?.map((card) => (
        <StoryblokComponent blok={card} />
      ))}
    </div>
  </div>
</section>
