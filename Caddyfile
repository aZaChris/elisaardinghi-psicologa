# Configurazione del server web Caddy per il dominio principale e www
elisaardinghi.it, www.elisaardinghi.it {
    
    # Redirige automaticamente tutto il traffico da www.elisaardinghi.it a elisaardinghi.it (HTTPS)
    @www host www.elisaardinghi.it
    redir @www https://elisaardinghi.it{uri}

    # Definisce la cartella radice dove si trovano i file compilati del sito sulla VPS
    root * /var/www/elisaardinghi
    # Abilita il server a servire file statici
    file_server

    # Abilita la compressione (Gzip e Zstd) per velocizzare il caricamento delle pagine
    encode gzip zstd

    # Gestione delle rotte per Astro e Decap CMS
    # Prova a servire il file richiesto ({path}), se non esiste prova la cartella ({path}/), 
    # altrimenti rimanda a index.html (essenziale per le rotte dell'admin e pagine dinamiche)
    try_files {path} {path}/ /index.html

    # Header di sicurezza consigliati per proteggere il sito da attacchi comuni
    header {
        # Forza l'uso di HTTPS per un anno
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        # Impedisce al browser di interpretare file come tipi MIME diversi da quelli dichiarati
        X-Content-Type-Options "nosniff"
        # Impedisce che il sito venga inserito in iframe di altri domini (anti-clickjacking)
        X-Frame-Options "SAMEORIGIN"
    }

    # Configurazione della cache per i file statici (immagini, stili, script)
    # Questi file non cambiano spesso, quindi li facciamo memorizzare nel browser per 1 anno
    @static {
        path *.ico *.css *.js *.gif *.webp *.avif *.jpg *.jpeg *.png *.svg *.woff *.woff2
    }
    header @static Cache-Control "public, max-age=31536000, immutable"
}
